// ===== SOKO YETU - DATABASE SCHEMA =====
// This schema is modeled directly on the frontend's existing data shapes:
// js/data.js (CATEGORIES, COUNTRIES, LISTINGS, SELLERS), js/post-ad.js (ad creation),
// js/dashboard.js ("my ads"), js/listing.js (offers/callbacks/reports/chat), js/auth.js (register/login).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USERS =====
// Maps to auth.js (register/login) + listing.js's seller card (verified, memberSince,
// feedbackCount, responseTime) + settings.js (account/notification/privacy tabs).

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String?   @unique
  phone         String    @unique
  passwordHash  String
  countryCode   String    // FK to Country.code, e.g. "KE"
  country       Country   @relation(fields: [countryCode], references: [code])

  // Seller profile fields (shown on listing.html's seller card)
  verified      Boolean   @default(false)
  memberSince   DateTime  @default(now())
  responseTime  String    @default("within a day") // e.g. "within an hour" - could become computed later

  // Moderation - no signup flow sets this; grant it manually in the DB for
  // trusted accounts only. Powers the admin listing-approval endpoints.
  isAdmin       Boolean   @default(false)

  // Settings (settings.js notifications + privacy tabs)
  notifyEmail   Boolean   @default(true)
  notifySms     Boolean   @default(true)
  showPhone     Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  listings      Listing[]
  offersSent    Offer[]      @relation("OfferBuyer")
  callbacks     Callback[]
  reportsFiled  Report[]     @relation("ReportFiler")
  savedAds      SavedAd[]
  messagesSent  Message[]    @relation("MessageSender")
  conversationsAsBuyer  Conversation[] @relation("ConversationBuyer")
  conversationsAsSeller Conversation[] @relation("ConversationSeller")
  feedbackReceived      Feedback[]     @relation("FeedbackForSeller")
  feedbackGiven         Feedback[]     @relation("FeedbackByAuthor")

  @@map("users")
}

// ===== COUNTRIES =====
// Maps to COUNTRIES array in data.js - static reference data, seeded once.

model Country {
  code         String    @id // "KE", "UG", etc.
  name         String
  currency     String    // "KES", "UGX", etc.
  dialCode     String    // "+254"
  exampleCity  String

  users        User[]
  listings     Listing[]

  @@map("countries")
}

// ===== CATEGORIES & SUBCATEGORIES =====
// Maps to CATEGORIES array in data.js - static reference data, seeded once.

model Category {
  id             String         @id // "vehicles", "phones", etc.
  name           String
  icon           String         // emoji used as placeholder image

  subcategories  Subcategory[]
  listings       Listing[]

  @@map("categories")
}

model Subcategory {
  id           String     @id // "cars", "smartphones", etc. (unique across all categories, matches frontend)
  name         String
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])

  listings     Listing[]

  @@map("subcategories")
}

// ===== LISTINGS =====
// Maps to LISTINGS array in data.js + the post-ad.js wizard (postAdState) +
// dashboard.js status workflow (pending/active/sold) + listing.js detail page.

enum ListingStatus {
  pending  // awaiting moderation review, like postAdState.status default
  active   // live and visible in search/browse
  sold
  rejected // failed moderation
}

model Listing {
  id             Int            @id @default(autoincrement())
  title          String
  price          Int            // 0 means "Negotiable" per formatPrice() in main.js
  negotiable     Boolean        @default(false)
  currency       String         // derived from country at creation time, e.g. "KES"
  description    String         @db.Text

  categoryId     String
  category       Category       @relation(fields: [categoryId], references: [id])
  subcategoryId  String?
  subcategory    Subcategory?   @relation(fields: [subcategoryId], references: [id])

  countryCode    String
  country        Country        @relation(fields: [countryCode], references: [code])
  city           String
  storeAddress   String?        // detailed seller location text, shown on listing.html

  specs          Json           // flexible key-value pairs, varies per category (Brand, Model, Mileage, etc.)
  photos         Photo[]

  sellerId       Int
  seller         User           @relation(fields: [sellerId], references: [id])

  status         ListingStatus  @default(pending)
  featured       Boolean        @default(false)
  views          Int            @default(0)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  offers         Offer[]
  callbacks      Callback[]
  reports        Report[]
  savedBy        SavedAd[]
  conversations  Conversation[]
  priceHistory   PriceHistoryEntry[]

  @@map("listings")
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([countryCode])
  @@index([status])
}

// ===== PHOTOS =====
// Maps to postAdState.photos (currently base64 data URLs in-browser only).
// Real backend stores uploaded files and serves their URLs instead.

model Photo {
  id          Int      @id @default(autoincrement())
  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url         String   // path/URL to the stored file
  position    Int      @default(0) // preserves the order shown in the photo grid

  @@map("photos")
}

// ===== PRICE HISTORY =====
// Maps to listing.js's getPriceHistoryData() - currently simulated client-side.
// Real backend can log actual price changes over time, or be seeded similarly at first.

model PriceHistoryEntry {
  id          Int      @id @default(autoincrement())
  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  price       Int
  recordedAt  DateTime @default(now())

  @@map("price_history_entries")
}

// ===== OFFERS =====
// Maps to listing.js's "Make an offer" modal (openOfferModal / submitOffer).

model Offer {
  id          Int      @id @default(autoincrement())
  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId     Int
  buyer       User     @relation("OfferBuyer", fields: [buyerId], references: [id])
  amount      Int
  createdAt   DateTime @default(now())

  @@map("offers")
}

// ===== CALLBACK REQUESTS =====
// Maps to listing.js's "Request call back" modal (openCallbackModal / submitCallback).
// Name/phone captured directly since the requester may not be logged in.

model Callback {
  id          Int      @id @default(autoincrement())
  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      Int?     // null if requester wasn't logged in
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  phone       String
  createdAt   DateTime @default(now())

  @@map("callbacks")
}

// ===== REPORTS =====
// Maps to listing.js's "Report ad" modal (openReportModal / submitReport).

enum ReportStatus {
  open
  reviewed
  dismissed
}

model Report {
  id          Int          @id @default(autoincrement())
  listingId   Int
  listing     Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  filedById   Int?
  filedBy     User?        @relation("ReportFiler", fields: [filedById], references: [id])
  reason      String
  details     String?      @db.Text
  status      ReportStatus @default(open)
  createdAt   DateTime     @default(now())

  @@map("reports")
}

// ===== SAVED ADS =====
// Maps to the "Saved ads" header icon panel (currently always empty in Phase 1).

model SavedAd {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   Int
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, listingId]) // can't save the same ad twice
  @@map("saved_ads")
}

// ===== SELLER FEEDBACK =====
// Maps to listing.js's seller card (seller.feedbackCount) and the "Feedback" banner
// link on listing.html. Any logged-in user can leave feedback on a seller - not
// restricted to verified buyers, since Phase 1 has no purchase-confirmation flow yet.

model Feedback {
  id          Int      @id @default(autoincrement())
  sellerId    Int
  seller      User     @relation("FeedbackForSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  authorId    Int
  author      User     @relation("FeedbackByAuthor", fields: [authorId], references: [id])
  rating      Int      // 1-5 stars
  comment     String?  @db.Text
  createdAt   DateTime @default(now())

  @@unique([sellerId, authorId]) // one feedback entry per author per seller - resubmitting updates it instead
  @@map("feedback")
  @@index([sellerId])
}
// ===== MESSAGING =====
// Maps to listing.js's chat modal (openChatModal / sendChatMessage) -
// currently in-memory only with fake auto-replies. One Conversation per
// buyer+listing pair, since that's how the frontend chat is scoped.

model Conversation {
  id          Int       @id @default(autoincrement())
  listingId   Int
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId     Int
  buyer       User      @relation("ConversationBuyer", fields: [buyerId], references: [id])
  sellerId    Int
  seller      User      @relation("ConversationSeller", fields: [sellerId], references: [id])

  createdAt   DateTime  @default(now())
  messages    Message[]

  @@unique([listingId, buyerId]) // one thread per buyer per listing
  @@map("conversations")
}

model Message {
  id              Int          @id @default(autoincrement())
  conversationId  Int
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        Int
  sender          User         @relation("MessageSender", fields: [senderId], references: [id])
  text            String       @db.Text
  createdAt       DateTime     @default(now())
  readAt          DateTime?    // null = unread. Set when the recipient (not the sender) views the conversation.

  @@map("messages")
  @@index([conversationId, readAt]) // speeds up "unread count in this conversation" and "mark all as read"
}

